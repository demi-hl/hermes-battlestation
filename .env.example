# DEMI Workspace — server-side config. Never expose these to the client.

# Hermes dashboard base (loopback). Used server-side to scrape the per-process
# session token and proxy /api/cron/jobs. The browser never sees the token.
HERMES_DASHBOARD_URL=http://127.0.0.1:9119

# Embedded chat target for the center pane iframe. Browse from the PC (the
# dashboard binds loopback and rejects non-loopback Host headers), so this
# stays a 127.0.0.1 URL.
NEXT_PUBLIC_HERMES_CHAT_URL=http://127.0.0.1:9119/chat

# Obsidian vault root (resolves OBSIDIAN_VAULT_PATH from ~/.hermes/.env).
OBSIDIAN_VAULT_PATH=/mnt/c/Users/demig/iCloudDrive/Documents/Obsidian Vault

# Fleet SSH hosts (aliases from ~/.ssh/config). PC is local, no ssh.
FLEET_HOSTS=gpu3070,demi-poly,ccmb

# Polymarket bot host alias + PM2 process name prefix.
POLY_HOST=demi-poly
POLY_PROC=demi-server
