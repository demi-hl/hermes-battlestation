default_platform(:ios)

PROJECT = "Hermes Battlestation.xcodeproj"
SCHEME  = "Hermes Battlestation"

# Account-specific identifiers. Override via env for your own App Store Connect
# account/app; the defaults are this repo's own. The private key (.p8) is NEVER
# committed — place it at ~/.appstoreconnect/private_keys/AuthKey_<KEYID>.p8.
ASC_KEY_ID    = ENV["ASC_KEY_ID"]    || "48PA68UN7R"
ASC_ISSUER_ID = ENV["ASC_ISSUER_ID"] || "0bc1b4b6-507c-42b7-802b-40fa7722fea6"
APP_ID        = ENV["ASC_APP_IDENTIFIER"] || "la.demi.battlestation"
TEAM_ID       = ENV["ASC_TEAM_ID"] || "5BV985Z9LJ"

platform :ios do
  desc "Build and upload Battlestation to TestFlight (headless, API key)"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ASC_KEY_ID,
      issuer_id: ASC_ISSUER_ID,
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ASC_KEY_ID}.p8"),
      in_house: false
    )

    build = Time.now.strftime("%Y%m%d%H%M")
    UI.message("Build number: #{build}")

    # Ensure a Distribution cert + App Store provisioning profile exist for this
    # team, created/downloaded via the API key. THIS IS THE FIX: exportArchive
    # needs an account + an "iOS Distribution" identity, which the bare API key
    # alone does NOT provision during export. Without cert+sigh, a clean machine
    # (no Distribution cert in the keychain) fails the export with
    # "No Accounts / No signing certificate 'iOS Distribution' found", even
    # though the archive step succeeds. Running cert+sigh first creates them.
    cert(
      development: false,
      output_path: File.expand_path("~/fastlane-certs")
    )
    sigh(
      app_identifier: APP_ID,
      platform: "ios",
      output_path: File.expand_path("~/fastlane-certs")
    )

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      output_directory: File.expand_path("~/fastlane-build"),
      output_name: "HermesBattlestation.ipa",
      xcargs: "CURRENT_PROJECT_VERSION=#{build} -allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        teamID: TEAM_ID,
        manageAppVersionAndBuildNumber: false,
        uploadSymbols: true,
        stripSwiftSymbols: true
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
