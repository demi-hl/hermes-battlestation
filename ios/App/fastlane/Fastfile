default_platform(:ios)

PROJECT = "Hermes Battlestation.xcodeproj"
SCHEME  = "Hermes Battlestation"

ASC_KEY_ID    = ENV["ASC_KEY_ID"]    || "48PA68UN7R"
ASC_ISSUER_ID = ENV["ASC_ISSUER_ID"] || "0bc1b4b6-507c-42b7-802b-40fa7722fea6"
APP_ID        = ENV["ASC_APP_IDENTIFIER"] || "la.demi.battlestation"
TEAM_ID       = ENV["ASC_TEAM_ID"] || "5BV985Z9LJ"

# Ephemeral CI keychain — avoids login.keychain-db locking in SSH/headless sessions.
# The login keychain locks on screen-lock/sleep even with no-timeout, causing
# errSecInternalComponent when codesign tries to access the Distribution key.
CI_KEYCHAIN_NAME     = "hermes-battlestation-ci"
CI_KEYCHAIN_PASSWORD = "ci-battlestation-2026"
CERTS_DIR            = File.expand_path("~/fastlane-certs")
P12_PATH             = File.join(CERTS_DIR, "G8QZ6KJ845.p12")
P12_PASSWORD         = ""

platform :ios do
  desc "Build and upload Battlestation to TestFlight (headless, API key)"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ASC_KEY_ID,
      issuer_id: ASC_ISSUER_ID,
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ASC_KEY_ID}.p8"),
      in_house: false
    )

    build = Time.now.strftime("%Y%m%d%H%M")
    UI.message("Build number: #{build}")

    # --- Step 1: Download/refresh Distribution cert + App Store profile ---
    cert(
      development: false,
      output_path: CERTS_DIR
    )
    profile_uuid = sigh(
      app_identifier: APP_ID,
      platform: "ios",
      output_path: CERTS_DIR
    )

    # --- Step 2: Create ephemeral CI keychain, import cert+key ---
    begin
      delete_keychain(name: CI_KEYCHAIN_NAME)
    rescue => e
      UI.message("No stale CI keychain: #{e.message}")
    end

    create_keychain(
      name:               CI_KEYCHAIN_NAME,
      password:           CI_KEYCHAIN_PASSWORD,
      default_keychain:   false,
      unlock:             true,
      timeout:            3600,
      lock_when_sleeps:   false,
      add_to_search_list: true
    )

    import_certificate(
      certificate_path:     P12_PATH,
      certificate_password: P12_PASSWORD,
      keychain_name:        CI_KEYCHAIN_NAME,
      keychain_password:    CI_KEYCHAIN_PASSWORD
    )

    # Get the actual keychain path fastlane created (avoids .keychain vs .keychain-db guesswork)
    keychain_db = Actions.lane_context[SharedValues::KEYCHAIN_PATH]
    UI.message("CI keychain path: #{keychain_db}")
    sh("ls -la #{keychain_db} 2>&1 || echo 'FILE NOT FOUND'")
    sh("security set-key-partition-list " \
       "-S apple-tool:,apple:,codesign: " \
       "-s -k #{CI_KEYCHAIN_PASSWORD} " \
       "-D \'Apple Distribution: Chris Gervais (#{TEAM_ID})\' " \
       "-t private " \
       "#{keychain_db}")

    # --- Step 3: Archive + export IPA ---
    build_app(
      project:          PROJECT,
      scheme:           SCHEME,
      configuration:    "Release",
      clean:            true,
      export_method:    "app-store",
      output_directory: File.expand_path("~/fastlane-build"),
      output_name:      "HermesBattlestation.ipa",
      xcargs:           "CURRENT_PROJECT_VERSION=#{build} " \
                        "CODE_SIGN_STYLE=Manual " \
                        "CODE_SIGN_IDENTITY=\"Apple Distribution\" " \
                        "DEVELOPMENT_TEAM=#{TEAM_ID} " \
                        "PROVISIONING_PROFILE=\"#{profile_uuid}\" " \
                        "-allowProvisioningUpdates",
      export_options: {
        signingStyle:                   "manual",
        teamID:                         TEAM_ID,
        provisioningProfiles:           { APP_ID => profile_uuid },
        manageAppVersionAndBuildNumber: false,
        uploadSymbols:                  true,
        stripSwiftSymbols:              true
      }
    )

    # --- Step 4: Upload to TestFlight ---
    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      skip_submission:                   true
    )

  ensure
    begin
      delete_keychain(name: CI_KEYCHAIN_NAME)
    rescue => e
      UI.message("CI keychain cleanup: #{e.message}")
    end
  end
end
